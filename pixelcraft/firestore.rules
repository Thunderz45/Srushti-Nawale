rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper check to verify if the user is authenticated
    function signedIn() {
      return request.auth != null;
    }
    
    // Helper check to verify if the auth user matches the requested user document UID
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // Allow creation only if the signed-in user is creating their own profile with 5 default credits
      allow create: if isOwner(userId) && 
                    request.resource.data.credits == 5 &&
                    request.resource.data.subscriptionStatus == 'free';
                    
      // Allow profile and credit updates if owner is authenticated
      allow update: if isOwner(userId);
      
      // Users cannot delete their accounts/credit profiles directly
      allow delete: if false;
    }

    match /credit_transactions/{txId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      
      // Allow creation of transactions only if the transaction logs belong to the authenticated owner
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      
      // Credit logs are audit trails and should never be updated or deleted
      allow update, delete: if false;
    }
  }
}
